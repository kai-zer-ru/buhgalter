# Скопируйте в .env рядом с docker-compose.yml:
#   cp .env.example .env
#
# Docker Compose подставляет переменные из .env и передаёт их в контейнер.
# Приложение только читает .env при старте; файл редактирует пользователь.

# --- Docker Compose (только для compose, в контейнер не передаётся) ---
BUHGALTER_IMAGE_TAG=latest

# --- Приложение (пути для Docker; на хосте: ./data, ./logs и т.д.) ---
BUHGALTER_ADDR=:8765
BUHGALTER_DB_PATH=/app/data/buhgalter.db
BUHGALTER_DATA_DIR=/app/data
BUHGALTER_LOG_DIR=/app/logs
BUHGALTER_LOG_MODE=prod
# Путь к .env внутри контейнера (задаётся в docker-compose.yml)
BUHGALTER_ENV_FILE=/app/.env

# --- Хостовые каталоги (bind mounts) ---
BUHGALTER_HOST_DATA_DIR=./data
BUHGALTER_HOST_BACKUPS_DIR=./backups
BUHGALTER_HOST_LOGS_DIR=./logs

# Host для прямого доступа без reverse proxy (JSON-массив). localhost всегда разрешён.
BUHGALTER_ALLOWED_HOSTS=[]

# Опционально:
# BUHGALTER_CORS_ORIGINS=*        # "*" отражает Origin запроса (для cookie-сессий)
# BUHGALTER_STATIC_EMBED=false    # для dev-сценария с отдельным Vite, обычно не нужен в релизе
